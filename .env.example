# Copy this file to `.env` and fill in your own values.
# Never commit the real `.env`. It is git-ignored for you.

# Optional read-only public personal access token.
# Used only to raise the GitHub rate limit from 60 to 5,000 req/hr.
# Create one with no scopes selected. Public read is all we need.
GITHUB_TOKEN=replace_me_optional_read_only_public_token

# The Gmail account that sends the digest email.
GMAIL_ADDRESS=you@gmail.com

# A Gmail App Password (16 chars), not your normal password.
# See the README for how to generate one. Requires 2-Step Verification.
GMAIL_APP_PASSWORD=replace_me_16_char_app_password

# Where the digest is delivered. Can be the same as GMAIL_ADDRESS.
NOTIFY_TO=you@gmail.com
